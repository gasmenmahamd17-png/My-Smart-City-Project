"use client"

import { useRef } from "react"
import { useFrame } from "@react-three/fiber"
import type * as THREE from "three"

function Vehicle({
  path,
  speed,
  color,
  size = 0.15,
}: {
  path: [number, number, number][]
  speed: number
  color: string
  size?: number
}) {
  const groupRef = useRef<THREE.Group>(null)
  const progressRef = useRef(Math.random())

  useFrame((_, delta) => {
    if (!groupRef.current) return
    progressRef.current = (progressRef.current + delta * speed) % 1

    const t = progressRef.current
    const totalSegments = path.length - 1
    const segIndex = Math.floor(t * totalSegments)
    const segT = (t * totalSegments) % 1

    const p1 = path[segIndex]
    const p2 = path[Math.min(segIndex + 1, path.length - 1)]

    const x = p1[0] + (p2[0] - p1[0]) * segT
    const y = p1[1] + (p2[1] - p1[1]) * segT + 0.1
    const z = p1[2] + (p2[2] - p1[2]) * segT

    groupRef.current.position.set(x, y, z)

    // Orientation
    const dx = p2[0] - p1[0]
    const dz = p2[2] - p1[2]
    if (Math.abs(dx) > 0.01 || Math.abs(dz) > 0.01) {
      groupRef.current.rotation.y = Math.atan2(dx, dz)
    }
  })

  return (
    <group ref={groupRef}>
      {/* Vehicle body */}
      <mesh castShadow>
        <boxGeometry args={[size * 0.6, size * 0.4, size]} />
        <meshStandardMaterial color={color} roughness={0.3} metalness={0.7} />
      </mesh>

      {/* Headlights */}
      <mesh position={[size * 0.15, 0, size * 0.5]}>
        <sphereGeometry args={[0.02]} />
        <meshStandardMaterial color="#ffffff" emissive="#ffffff" emissiveIntensity={3} />
      </mesh>
      <mesh position={[-size * 0.15, 0, size * 0.5]}>
        <sphereGeometry args={[0.02]} />
        <meshStandardMaterial color="#ffffff" emissive="#ffffff" emissiveIntensity={3} />
      </mesh>

      {/* Tail lights */}
      <mesh position={[size * 0.15, 0, -size * 0.5]}>
        <sphereGeometry args={[0.02]} />
        <meshStandardMaterial color="#ff3333" emissive="#ff3333" emissiveIntensity={2} />
      </mesh>
      <mesh position={[-size * 0.15, 0, -size * 0.5]}>
        <sphereGeometry args={[0.02]} />
        <meshStandardMaterial color="#ff3333" emissive="#ff3333" emissiveIntensity={2} />
      </mesh>

      {/* Glow underneath */}
      <pointLight color={color} intensity={0.5} distance={1} position={[0, -0.05, 0]} />
    </group>
  )
}

function Drone({
  center,
  radius,
  height,
  speed,
}: {
  center: [number, number, number]
  radius: number
  height: number
  speed: number
}) {
  const groupRef = useRef<THREE.Group>(null)
  const timeRef = useRef(Math.random() * Math.PI * 2)

  useFrame((_, delta) => {
    if (!groupRef.current) return
    timeRef.current += delta * speed

    const x = center[0] + Math.cos(timeRef.current) * radius
    const z = center[2] + Math.sin(timeRef.current) * radius
    const y = height + Math.sin(timeRef.current * 2) * 0.3

    groupRef.current.position.set(x, y, z)
    groupRef.current.rotation.y = -timeRef.current
  })

  return (
    <group ref={groupRef}>
      {/* Drone body */}
      <mesh>
        <octahedronGeometry args={[0.08]} />
        <meshStandardMaterial color="#1a2a3a" metalness={0.8} roughness={0.2} />
      </mesh>

      {/* Propellers */}
      {[
        [0.12, 0.02, 0.12],
        [-0.12, 0.02, 0.12],
        [0.12, 0.02, -0.12],
        [-0.12, 0.02, -0.12],
      ].map((pos, i) => (
        <mesh key={i} position={pos as [number, number, number]}>
          <cylinderGeometry args={[0.06, 0.06, 0.01, 8]} />
          <meshStandardMaterial color="#00d4ff" emissive="#00d4ff" emissiveIntensity={1} transparent opacity={0.5} />
        </mesh>
      ))}

      {/* Light */}
      <pointLight color="#00d4ff" intensity={1} distance={3} />
      <mesh position={[0, -0.06, 0]}>
        <sphereGeometry args={[0.03]} />
        <meshStandardMaterial color="#00d4ff" emissive="#00d4ff" emissiveIntensity={3} />
      </mesh>
    </group>
  )
}

